{
  "name": "rentease-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "node ./node_modules/vite/bin/vite.js --host 127.0.0.1 --port 5173",
    "server": "node server/index.js",
    "build": "node ./node_modules/vite/bin/vite.js build",
